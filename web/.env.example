# =============================================================================
# Nordic Works — Environment Variables Template
#
# Usage:
#   1. Copy this file to .env.local
#   2. Replace placeholder values with real ones
#   3. .env.local is gitignored (per web/.gitignore)
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others stay server-side.
# =============================================================================

# -----------------------------------------------------------------------------
# WordPress connection (Week 3〜)
# -----------------------------------------------------------------------------

# REST API base URL (no trailing slash)
WORDPRESS_API_URL=http://nordic-works.local/wp-json

# GraphQL endpoint (provided by WPGraphQL plugin)
WORDPRESS_GRAPHQL_URL=http://nordic-works.local/graphql

# -----------------------------------------------------------------------------
# Site identity (Week 4 / SEO)
# -----------------------------------------------------------------------------

# サイトの公開URL（sitemap.xml・canonical・OGP の絶対URL生成に使用）
# 開発: http://localhost:3000  / 本番: https://nordic-works.example.com 等
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Data source switch (Week 8 で本格利用)
#
# - "api"    : 開発時。ライブの WP API からデータ取得
# - "static" : 本番ビルド時。data/*.json から読み込み（Vercel デプロイ用）
# -----------------------------------------------------------------------------

DATA_SOURCE=api

# -----------------------------------------------------------------------------
# Preview & Revalidation (Week 5)
#
# 下書きプレビュー機能と On-demand Revalidation で使う秘密トークン。
# WordPress 側の functions.php と必ず一致させること。
# 本番では十分にランダムな文字列を使うこと（openssl rand -hex 32 等）。
# -----------------------------------------------------------------------------

WORDPRESS_PREVIEW_SECRET=replace-with-random-string-for-preview
REVALIDATE_SECRET=replace-with-random-string-for-revalidate

# -----------------------------------------------------------------------------
# WordPress 認証（Week 5、下書きプレビュー時の認証付き取得用）
#
# WP 管理画面 → ユーザー → プロフィール → アプリケーションパスワード から発行する。
# 通常のログインパスワードではなく、必ず Application Password を使うこと。
# -----------------------------------------------------------------------------

WP_USERNAME=
WP_APPLICATION_PASSWORD=

# -----------------------------------------------------------------------------
# Algolia (Week 6)
#
# 全文検索エンジン。Free プランで月10,000リクエストまで利用可能。
# https://www.algolia.com/
# -----------------------------------------------------------------------------

NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=
NEXT_PUBLIC_ALGOLIA_INDEX_NAME=nordic_works

# -----------------------------------------------------------------------------
# Resend (Week 6、お問い合わせフォームのメール送信)
#
# 開発者向けメール API。Free プランで月100通まで利用可能。
# https://resend.com/
# -----------------------------------------------------------------------------

RESEND_API_KEY=
CONTACT_EMAIL_FROM=noreply@nordicworks.example.com
CONTACT_EMAIL_TO=info@nordicworks.example.com
