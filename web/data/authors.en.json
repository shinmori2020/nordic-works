      "rendered": "Misaki Sato"
    },
    "content": {
      "rendered": "<p>Over 10 years career as an Organizational Development Consultant. Engaged in organizational changes of various sizes and industries, from startups to listed companies. He has written and lectured extensively on remote work culture and psychological safety.</p>\n",
      "protected": false
    },
    "featured_media": 68,
    "template": "",
    "meta": {
