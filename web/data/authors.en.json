      "hentry"
    ],
    "acf": {
      "photo": 69,
      "position": "Organizational Development Lead",
      "bio": "Support the introduction of 1: 1 feedback design regardless of job type, from startups to large companies.Numerous contributions on the management of tech organizations.Previously, he spent 5 years as a manager in a 100-person engineering organization.\nLeveraging their technical background, they hold management training and one-on-one workshops for engineers more than 20 times a year.He is good at conveying \"organizational theory that makes sense from the point of view of engineers\".A recent interest is the design of evaluation systems for engineer organizations.",
      "twitter_url": "https://twitter.com/example_tanaka",
      "linkedin_url": "https://linkedin.com/in/example-tanaka",
      "website_url": ""
    },
