    ],
    "acf": {
      "photo": 70,
      "position": "Nordic Cultural Advisor",
      "bio": "It is responsible for translating Nordic work styles and organizational culture to B2B companies in Japan.Trilingual in Swedish, English and Japanese.He has lived in Japan for 8 years and worked at an organization consulting firm in Stockholm in the past.\nHe is good at the approach of \"translating the Scandinavian model into the Japanese context rather than importing it as it is\".He has worked on many lectures and writings to convey Nordic practices to Japanese companies, such as flat organization, work-life integration, and male parental leave culture.His hobby is visiting hot springs in various parts of Japan.",
      "twitter_url": "",
      "linkedin_url": "https://linkedin.com/in/example-lindberg",
      "website_url": "https://example.com/anna"
