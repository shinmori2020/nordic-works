    "title": {
      "rendered": "Lindbergh Anna"
    },
    "content": {
      "rendered": "<p>Nordic cultural advisor from Stockholm. It is responsible for translating Nordic work styles and organizational culture to B2B companies in Japan. Trilingual in Swedish, English and Japanese.</p>\n",
      "protected": false
    },
    "featured_media": 70,
    "template": "",
    "meta": {
      "_acf_changed": false
    },
    "class_list": [
      "post-48",
