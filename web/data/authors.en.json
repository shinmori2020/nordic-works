    "title": {
      "rendered": "Kenichi Tanaka"
    },
    "content": {
      "rendered": "<p>Former Engineer Manager, Current Org Development Lead. Support the transformation of the engineering organization with a unique approach that blends hands-on experience as a manager of the technical organization with organizational development expertise.</p>\n",
      "protected": false
    },
    "featured_media": 69,
    "template": "",
    "meta": {
      "_acf_changed": false
    },
    "class_list": [
      "post-47",
