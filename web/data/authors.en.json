  {
    "id": 46,
    "date": "2026-05-14T11:03:36",
    "date_gmt": "2026-05-14T11:03:36",
    "guid": {
      "rendered": "http://nordic-works.local/authors/sato-misaki/"
    },
    "modified": "2026-05-28T10:14:00",
    "modified_gmt": "2026-05-28T10:14:00",
    "slug": "sato-misaki",
    "status": "publish",
    "type": "author_profile",
    "link": "http://localhost:3000/authors/sato-misaki",
    "title": {
      "rendered": "佐藤 美咲"
    },
    "content": {
      "rendered": "<p>組織開発コンサルタントとして10年以上のキャリア。スタートアップから上場企業まで、多様な規模・業種の組織変革に携わる。リモートワーク文化・心理的安全性に関する執筆・登壇多数。</p>\n",
      "protected": false
    },
    "featured_media": 68,
    "template": "",
    "meta": {
      "_acf_changed": false
    },
    "class_list": [
      "post-46",
      "author_profile",
      "type-author_profile",
      "status-publish",
      "has-post-thumbnail",
      "hentry"
    ],
    "acf": {
      "photo": 68,
      "position": "シニアコンサルタント",
      "bio": "大手SaaS企業のチームビルディング支援に多数携わる。前職はグローバルコンサルティングファームで組織変革プロジェクトをリード。心理的安全性に関する執筆は、雑誌・Webメディア合わせて50本以上。\n大学院では組織心理学を専攻し、修士号取得。研究と実務の両面から組織を見る視点を大切にしている。最近の関心領域は、リモート時代のチームビルディングと、評価制度の納得感設計。",
      "twitter_url": "https://twitter.com/example_sato",
      "linkedin_url": "https://linkedin.com/in/example-sato",
      "website_url": ""
    },
