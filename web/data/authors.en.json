  {
    "id": 47,
    "date": "2026-05-14T11:03:36",
    "date_gmt": "2026-05-14T11:03:36",
    "guid": {
      "rendered": "http://nordic-works.local/authors/tanaka-kenichi/"
    },
    "modified": "2026-05-28T10:14:04",
